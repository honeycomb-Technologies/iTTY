		<key>UIColorName</key>
		<string>LaunchBackground</string>
		<key>UIImageName</key>
		<string>LaunchLogo</string>
	</dict>
	<key>UIRequiresFullScreen</key>
	<false/>
	<key>UISupportsMultipleScenes</key>
	<true/>
