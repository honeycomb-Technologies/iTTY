		<string>Inconsolata-Regular.ttf</string>
		<string>Inconsolata-Bold.ttf</string>
		<string>AtkinsonHyperlegibleMono-Regular.ttf</string>
		<string>AtkinsonHyperlegibleMono-Bold.ttf</string>
	</array>
